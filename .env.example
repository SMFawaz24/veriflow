# Veriflow — Environment Configuration
# Copy this file to .env and fill in your values

# ── SERVER ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── UPLOAD LIMITS ──────────────────────────────────────────
MAX_FILE_MB=100

# ── SECURITY ───────────────────────────────────────────────
# Download token TTL in milliseconds (default: 30 minutes)
TOKEN_TTL_MS=1800000

# Allowed origins for CORS (comma-separated, or * for all)
CORS_ORIGINS=https://veriflow.f4w4z.dev

# ── RATE LIMITING ──────────────────────────────────────────
# Max requests per IP per minute on /api/process
RATE_LIMIT_RPM=10
